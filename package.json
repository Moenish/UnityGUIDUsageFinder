{
  "name": "unity-guid-usage-finder",
  "displayName": "Unity GUID Usage Finder",
  "description": "Find where Unity scripts are used in scenes, prefabs, and serialized assets by GUID.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:unityGuidUsageFinder.findScriptUsages",
    "onCommand:unityGuidUsageFinder.refreshLastSearch",
    "onCommand:unityGuidUsageFinder.clearResults",
    "onCommand:unityGuidUsageFinder.copyCurrentScriptGuid",
    "onCommand:unityGuidUsageFinder.showScanHistory",
    "onCommand:unityGuidUsageFinder.loadHistoryEntry",
    "onCommand:unityGuidUsageFinder.revealUsageInExplorer",
    "onCommand:unityGuidUsageFinder.openAllUsages",
    "onCommand:unityGuidUsageFinder.clearScanHistory",
    "onCommand:unityGuidUsageFinder.filterResults",
    "onCommand:unityGuidUsageFinder.clearFilter"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "unityGuidUsageFinder.findScriptUsages",
        "title": "Unity GUID: Find Script Usages by GUID"
      },
      {
        "command": "unityGuidUsageFinder.refreshLastSearch",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "unityGuidUsageFinder.clearResults",
        "title": "Clear",
        "icon": "$(trash)"
      },
      {
        "command": "unityGuidUsageFinder.copyCurrentScriptGuid",
        "title": "Unity GUID: Copy Script GUID"
      },
      {
        "command": "unityGuidUsageFinder.showScanHistory",
        "title": "History",
        "icon": "$(history)"
      },
      {
        "command": "unityGuidUsageFinder.loadHistoryEntry",
        "title": "Unity GUID: Load History Entry"
      },
      {
        "command": "unityGuidUsageFinder.revealUsageInExplorer",
        "title": "Reveal Usage in Explorer",
        "icon": "$(folder-opened)"
      },
      {
        "command": "unityGuidUsageFinder.openAllUsages",
        "title": "Open All Usages",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "unityGuidUsageFinder.clearScanHistory",
        "title": "Clear History",
        "icon": "$(trash)"
      },
      {
        "command": "unityGuidUsageFinder.filterResults",
        "title": "Filter Results",
        "icon": "$(search)"
      },
      {
        "command": "unityGuidUsageFinder.clearFilter",
        "title": "Clear Filter",
        "icon": "$(close)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "unityGuidUsageFinder.findScriptUsages",
          "when": "resourceExtname == .cs",
          "group": "navigation"
        },
        {
          "command": "unityGuidUsageFinder.copyCurrentScriptGuid",
          "when": "resourceExtname == .cs",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "unityGuidUsageFinder.findScriptUsages",
          "when": "resourceExtname == .cs",
          "group": "navigation"
        },
        {
          "command": "unityGuidUsageFinder.copyCurrentScriptGuid",
          "when": "resourceExtname == .cs",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "unityGuidUsageFinder.refreshLastSearch",
          "when": "view == unityGuidUsageFinder.resultsView",
          "group": "navigation@1"
        },
        {
          "command": "unityGuidUsageFinder.clearResults",
          "when": "view == unityGuidUsageFinder.resultsView",
          "group": "navigation@2"
        },
        {
          "command": "unityGuidUsageFinder.openAllUsages",
          "when": "view == unityGuidUsageFinder.resultsView",
          "group": "navigation@3"
        },
        {
          "command": "unityGuidUsageFinder.clearScanHistory",
          "when": "view == unityGuidUsageFinder.historyView",
          "group": "navigation@1"
        },
        {
          "command": "unityGuidUsageFinder.filterResults",
          "when": "view == unityGuidUsageFinder.resultsView",
          "group": "navigation@4"
        },
        {
          "command": "unityGuidUsageFinder.clearFilter",
          "when": "view == unityGuidUsageFinder.resultsView",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "unityGuidUsageFinder.revealUsageInExplorer",
          "when": "view == unityGuidUsageFinder.resultsView && viewItem == usage",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "unityGuidUsageFinder",
          "title": "Unity GUID Finder",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "unityGuidUsageFinder": [
        {
          "id": "unityGuidUsageFinder.resultsView",
          "name": "Script Usages"
        },
        {
          "id": "unityGuidUsageFinder.historyView",
          "name": "Scan History"
        }
      ]
    },
    "configuration": {
      "title": "Unity GUID Usage Finder",
      "properties": {
        "unityGuidUsageFinder.includeGlobs": {
          "type": "array",
          "default": [
            "Assets/**/*.unity",
            "Assets/**/*.prefab",
            "Assets/**/*.asset",
            "Assets/**/*.controller",
            "Assets/**/*.overrideController",
            "Assets/**/*.anim",
            "Assets/**/*.mat"
          ],
          "description": "Unity serialized files to scan for script GUID usages."
        },
        "unityGuidUsageFinder.excludeGlob": {
          "type": "string",
          "default": "**/{Library,Temp,Obj,Build,Builds,Logs,Packages}/**",
          "description": "Files/folders to exclude while scanning."
        },
        "unityGuidUsageFinder.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh the last Unity GUID scan when serialized Unity assets change."
        },
        "unityGuidUsageFinder.autoRefreshDebounceMs": {
          "type": "number",
          "default": 750,
          "minimum": 100,
          "maximum": 10000,
          "description": "Delay before auto-refreshing after Unity serialized assets change."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}